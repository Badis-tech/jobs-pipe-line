# Publishable key only — never put the service_role/secret key in the client bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Lemon Squeezy (server-side only; never exposed to the browser) ---
# Fill these once your LS store + product exist.
# Settings -> API (key) | Settings -> Stores (store id) | product variant page (variant id)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
# Webhook signing secret: Settings -> Webhooks -> your webhook -> Signing secret
LEMONSQUEEZY_WEBHOOK_SECRET=

# --- Supabase service role (server-side only; the webhook uses it to flip
# subscription status). NEVER commit. NEVER prefix with NEXT_PUBLIC_. ---
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL, used for checkout redirect + webhook callback URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
